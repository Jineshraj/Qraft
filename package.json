{
  "name": "qraft-upi-qr",
  "version": "0.1.3",
  "description": "Qraft - UPI QR & label generator for React",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.es.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./style.css": "./dist/style.css",
    "./dist/style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "upi",
    "qr",
    "react",
    "payments",
    "label",
    "qraft"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "html2canvas": "^1.4.1",
    "qrcode": "^1.5.3",
    "qrcode.react": "^3.1.0"
  },
  "peerDependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.5.4",
    "vite": "^8.0.3",
    "vite-plugin-css-injected-by-js": "^4.0.1",
    "vite-plugin-dts": "^1.0.5"
  }
}
